{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unreal MCP Packs",
  "type": "object",
  "required": ["version", "packs"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string" },
    "packs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "access": { "type": "string", "enum": ["read", "write", "mixed"] }
        }
      }
    }
  }
}
