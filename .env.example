# Repo-wide local configuration (copy to `.env`).
#
# Notes:
# - `.env` is gitignored.
# - The Unreal plugin prints UNREAL_TOKEN in the Unreal Output Log.

# Your UE project directory (folder containing the .uproject)
UNREAL_PROJECT_DIR=D:\UEProjects\BlueprintLesson\BlueprintLesson

# Unreal Engine install root (folder containing Engine/Build/BatchFiles/Build.bat)
UE_ENGINE_ROOT=C:\Program Files\Epic Games\UE_5.6

# Unreal plugin TCP endpoint
UNREAL_HOST=127.0.0.1
UNREAL_PORT=17777
UNREAL_TOKEN=

# Client-side request timeout (ms)
UNREAL_TIMEOUT_MS=2500

# Optional
# UNREAL_MOCK=1
